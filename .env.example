# Backend (Django) – use in Vercel env or locally
# Local dev: leave VERCEL unset (or set RUNNING_LOCALLY=1) so media use ./media/ and no Supabase required.
# Generate: openssl rand -base64 40
DJANGO_SECRET_KEY=your-secret-key
DEBUG=False
# Supabase: Settings → Database → Connection string (URI, pooler)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Supabase Storage (profile photos) – Settings → API → Project URL + service_role key
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Optional: bucket name (default: media)
# SUPABASE_MEDIA_BUCKET=media
# Comma-separated frontend URLs allowed by CORS
CORS_ORIGINS=https://your-app.vercel.app
# Public URLs used in transactional emails. FRONTEND_URL is the React SPA
# (used for "open the app" deep links). BACKEND_URL is the Django host that
# serves the unsubscribe view; if you deploy frontend + backend on the same
# host, you can leave BACKEND_URL unset and it will fall back to FRONTEND_URL.
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.vercel.app

# Brevo (transactional email). Leave EMAIL_HOST_USER blank locally to fall
# back to the Django console backend (emails printed to runserver log).
# Brevo dashboard → SMTP & API → SMTP → "SMTP key" generates these values.
EMAIL_HOST_USER=your-brevo-login@domain.com
EMAIL_HOST_PASSWORD=hghg6f55-cfdf
DEFAULT_FROM_EMAIL=Equilo <noreply@yourdomain.com>

# Shared secret required by /api/cron/* endpoints. On Vercel, set this env
# var and Vercel Cron will automatically attach it as
# `Authorization: Bearer <CRON_SECRET>` to every cron invocation.
# Generate locally: openssl rand -hex 32
CRON_SECRET=656f656f5fdssfj555