# Frontend (React)
#
# Local dev: leave VITE_API_URL unset. The Vite dev server proxies /api → Django (see vite.config.js);
# that same-origin setup is required for HttpOnly refresh cookies to work.
#
# Production build: set to your deployed API origin including /api
# VITE_API_URL=https://your-app.vercel.app/api
